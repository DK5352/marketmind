# MarketMind — environment variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git — it contains secret keys.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic Claude API — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Finnhub — free at https://finnhub.io (no credit card required)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage — free at https://alphavantage.co (25 calls/day, no credit card required)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ── Optional: Brokerage connection ───────────────────────────────────────────
# MarketMind supports three brokers. Fill in the section for the one you use.
# All values here are READ-ONLY — MarketMind reads positions but never
# places or cancels orders automatically.

# -- Option 1: Alpaca (recommended) ------------------------------------------
# Official API. Free paper + live trading. No credit card required.
# Get keys: https://alpaca.markets → Dashboard → API Keys → Generate New Key
# Paper (simulated, no real money):
ALPACA_API_KEY=your_alpaca_key_id_here
ALPACA_API_SECRET=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Live (real money) — replace the URL above with:
# ALPACA_BASE_URL=https://api.alpaca.markets

# -- Option 2: Robinhood (unofficial) ----------------------------------------
# Robinhood has NO public API. Connection uses the robin_stocks library which
# reverse-engineers the Robinhood mobile app. May break without warning.
# Install: pip install robin_stocks
# Credentials are NOT stored here (passwords should never be in plain text).
# You will be prompted to log in each session.

# -- Option 3: Interactive Brokers (IBKR) ------------------------------------
# Official API via ib_insync. Requires TWS or IB Gateway running locally.
# Install: pip install ib_insync
# Download TWS: https://www.interactivebrokers.com/en/trading/tws.php
# Paper port (TWS paper trading):
IBKR_PORT=7497
IBKR_ACCT_TYPE=paper
# Live port — replace with 7496 when using live TWS:
# IBKR_PORT=7496
